# Supabase Configuration
# 請複製此檔案為 .env 並填入實際值
# Supabase Project URL
# 從 Supabase Dashboard > Settings > API 取得
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key
# 從 Supabase Dashboard > Settings > API > Project API keys > anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 環境設定
# 1. 請複製此檔案為 .env 並填入實際值
# 2. 確保 .env 檔案已加入 .gitignore 避免提交敏感資訊
# 3. 根據不同環境（development/staging/production）設定不同的值
# 4. 重新啟動開發伺服器使環境變數生效

# App Environment
# 可選值: development, staging, production
EXPO_PUBLIC_APP_ENV=development

# Google OAuth Configuration
# 從 Google Cloud Console 取得
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Analytics Configuration
# Google Analytics 4 追蹤 ID
EXPO_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Sentry Crash / Error 監控
# 從 Sentry > 你的 project > Settings > Client Keys (DSN) 取得
# DSN 可公開（會打包進 app），但仍建議放 .env 統一管理
EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# Sentry source map 上傳用（僅 build 時需要，可選）
# 從 Sentry > Settings > Auth Tokens 建立，需有 project:releases 權限
# SENTRY_AUTH_TOKEN=sntrys_xxxxx
